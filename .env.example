# Trinity Spine — Environment Configuration Template
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control!

# ==================== TRINITY CORE CONFIG ====================
# Autonomy level: 0=MANUAL, 1=SEMI_AUTO, 2=FULL_AUTO
TRINITY_AUTONOMY_LEVEL=1
TRINITY_API_KEY=your-secret-api-key-change-in-production
TRINITY_SIGNING_SECRET=your-pqc-signing-secret-32-bytes-minimum
TRINITY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001

# ==================== TRINITY FEATURES ====================
# Enable/disable core subsystems
TRINITY_PQC_ENABLED=true
TRINITY_OUROBOROS_ENABLED=true
TRINITY_AUTONOMY_GATE_ENABLED=true
TRINITY_SYSTEM_SPAWNER_ENABLED=true

# ==================== OUROBOROS CONFIG ====================
# Health check interval in seconds (recommend 300 = 5 minutes)
TRINITY_AUDIT_INTERVAL=300
# Max retry attempts before escalation
TRINITY_MAX_RETRIES=3
# Keep last N regeneration events in memory
TRINITY_REGENERATION_LOG_LIMIT=1000
# Enable autonomous healing (retry → restart → rollback → spawn)
TRINITY_AUTO_HEALING_ENABLED=true

# ==================== LOGGING ====================
TRINITY_LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for development, INFO for production

# ==================== SUPABASE (Database & Auth) ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-keep-secret
SUPABASE_ANON_KEY=your-anonymous-key
# The service key is critical - it bypasses RLS for admin operations

# ==================== STRIPE (Payments) ====================
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Keep these keys secret! Never commit to version control.

# ==================== PostgreSQL (Local/Direct Connection) ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=trinity
POSTGRES_DB=trinity
POSTGRES_POOL_SIZE=20

# ==================== REDIS (Cache & Message Queue) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Leave password blank for local development

# ==================== PROMETHEUS (Metrics) ====================
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

# ==================== GRAFANA (Dashboards) ====================
GRAFANA_PASSWORD=trinity
GRAFANA_PORT=3000

# ==================== SYSTEM SPAWNER ====================
# Comma-separated list of systems to auto-spawn (daily at midnight)
TRINITY_SPAWNED_SYSTEMS=yur_ai,wav,wcc,sentinel,construction_wizard,rebirth,lotlogic,air_savior
# Default spawner interval (cron expression)
TRINITY_SPAWNER_SCHEDULE=0 0 * * *  # Midnight daily

# ==================== EXTERNAL INTEGRATIONS ====================
# elizaOS for character generation
ELIZAOS_API_URL=http://localhost:3001
ELIZAOS_API_KEY=your-eliza-api-key

# OpenAI / Alternative LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4
LLM_PROVIDER=openai  # or anthropic, local, etc.

# ==================== SECURITY & ISOLATION ====================
# CORS (Cross-Origin Resource Sharing)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
# CSP (Content Security Policy)
CSP_ENABLED=true
# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=3600

# ==================== KUBERNETES (if deploying to K8s) ====================
K8S_NAMESPACE=trinity-spine
K8S_REPLICAS=3
K8S_CPU_REQUEST=500m
K8S_CPU_LIMIT=2000m
K8S_MEMORY_REQUEST=512Mi
K8S_MEMORY_LIMIT=2Gi
K8S_HEALTH_CHECK_INTERVAL=30

# ==================== GOVERNANCE POLICIES ====================
# JSON-encoded governance policies (or path to policy file)
# For complex policies, use a separate governance-policies.json file
GOVERNANCE_POLICIES_FILE=./governance-policies.json
# Governance enforcement level: 0=warn, 1=enforce
GOVERNANCE_ENFORCEMENT_LEVEL=1

# ==================== MONITORING & ALERTING ====================
# PagerDuty integration
PAGERDUTY_API_KEY=
PAGERDUTY_SERVICE_ID=
# Slack webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Email for critical alerts
ALERT_EMAIL=ops@roosevelt-ventures.io

# ==================== DEVELOPMENT ONLY ====================
# Set to true only in development environments
DEBUG=false
ALLOW_UNVERIFIED_MISSIONS=false
SKIP_PQC_VERIFICATION=false

# ==================== BACKUP & DISASTER RECOVERY ====================
# S3 bucket for backups
BACKUP_S3_BUCKET=trinity-backups
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
# Backup frequency (hours)
BACKUP_INTERVAL_HOURS=24

# ==================== DOCKER COMPOSE SPECIFIC ====================
# Service discovery (docker-compose service names)
DB_HOST=postgres
REDIS_HOST=redis
PROMETHEUS_HOST=prometheus
# Timezone
TZ=UTC

# ==================== FRANKLINOPS HUB (LOCAL) ====================
# Local-first Ops hub + spokes for Sales/Finance workflows.
# Canonical folder mapping (JCK Concrete):
#   02BIDDING  → new opportunities (ITBs, RFQs, contacts)
#   01PROJECTS → active work (project docs, submittals)
#   Attachments → invoices, submittals, misc paperwork
# Set these to your OneDrive folder paths (e.g. C:\Users\...\OneDrive\...\02BIDDING)
FRANKLINOPS_DATA_DIR=data/franklinops
FRANKLINOPS_DB_PATH=data/franklinops/ops.db
FRANKLINOPS_AUDIT_JSONL_PATH=data/franklinops/audit.jsonl

FRANKLINOPS_ONEDRIVE_PROJECTS_ROOT=
FRANKLINOPS_ONEDRIVE_BIDDING_ROOT=
FRANKLINOPS_ONEDRIVE_ATTACHMENTS_ROOT=

# Trackable roots (Cursor project paths)
# Defaults point to C:\Users\jerem\.cursor\projects\ — override if your paths differ
FRANKLINOPS_SUPERAGENTS_ROOT=
FRANKLINOPS_BID_ZONE_ROOT=
FRANKLINOPS_FRANKLIN_OS_ROOT=
FRANKLINOPS_JCK_LAND_DEV_ROOT=
FRANKLINOPS_PC_CHANGE_ORDER=
FRANKLINOPS_PC_DOCUMENT=
FRANKLINOPS_PC_LONG_LEAD_MATERIAL=
FRANKLINOPS_PC_MATERIAL_DELIVERY=
FRANKLINOPS_PC_MATERIAL_RETURN=
FRANKLINOPS_PC_MATERIAL_SHORTAGE=
FRANKLINOPS_PC_PROJECT_ROSTER=
FRANKLINOPS_PC_RAIN_DELAY=
FRANKLINOPS_PC_RFI=
FRANKLINOPS_PC_SUBMITTAL=
FRANKLINOPS_PC_SUBSTITUTION=
FRANKLINOPS_PC_VALUE_ENGINEERING=

# Ingestion tuning (keep large plan sets bounded by default)
FRANKLINOPS_PDF_MAX_PAGES=2
FRANKLINOPS_PDF_MAX_CHARS=20000
FRANKLINOPS_XLSX_MAX_ROWS=5000
FRANKLINOPS_XLSX_MAX_CHARS=200000

# Cashflow waterfall import (anchor "MONTH=1" to this date)
FRANKLINOPS_WATERFALL_START_DATE=

# Superagents Fleet — external plugin directory (optional)
# FRANKLINOPS_FLEET_PLUGINS_DIR=path/to/custom/agents

# Bid Portal — SAM.gov (free API key from SAM.gov account)
# SAM_GOV_API_KEY=your-sam-gov-api-key

# Risk thresholds: actions exceeding these require human approval
FRANKLINOPS_RISK_MAX_APPROVAL_AMOUNT=5000.0

# Autonomy defaults for new workflows (shadow | assist | autopilot)
FRANKLINOPS_DEFAULT_GOVERNANCE_SCOPE=internal
FRANKLINOPS_DEFAULT_AUTHORITY_LEVEL=SEMI_AUTO
FRANKLINOPS_RATE_LIMIT_PER_HOUR=200
FRANKLINOPS_MAX_COST_PER_MISSION=1000.0
FRANKLINOPS_AUTOPILOT_AUDIT_SAMPLE_RATE=0.10

# ==================== FRANKLINOPS SALES (OUTBOUND EMAIL) ====================
# Delivery provider: manual | console | gmail | sendgrid
FRANKLINOPS_EMAIL_PROVIDER=manual
# From identity (used for SendGrid; Gmail ignores/overrides based on the account)
FRANKLINOPS_FROM_EMAIL=
FRANKLINOPS_FROM_NAME=JCK Concrete
# Safety: if set, ALL outbound email is redirected here (original recipient is logged in metadata)
FRANKLINOPS_RECIPIENT_OVERRIDE_EMAIL=
# When an approval is auto-approved or human-approved, attempt to send automatically
FRANKLINOPS_SALES_OUTBOUND_AUTO_SEND=true
# Extra safety limit (independent of AutonomyGate in-memory counters)
FRANKLINOPS_SALES_OUTBOUND_MAX_PER_HOUR=20
# Create a follow-up task 2 days after a send
FRANKLINOPS_SALES_OUTBOUND_CREATE_FOLLOWUP_TASK=true

# Gmail (OAuth) — required if FRANKLINOPS_EMAIL_PROVIDER=gmail
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# SendGrid — required if FRANKLINOPS_EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=

# Local LLM (Ollama) for Ops Chat (optional)
FRANKLINOPS_OLLAMA_API_URL=http://localhost:11434/api/generate
FRANKLINOPS_OLLAMA_MODEL=llama3

# ==================== PROCORE (OAUTH) ====================
# OAuth app credentials from Procore Developer Portal.
PROCORE_ENV=prod  # prod | sandbox | monthly
PROCORE_CLIENT_ID=
PROCORE_CLIENT_SECRET=
PROCORE_COMPANY_ID=
# Must match your Procore app redirect URI:
PROCORE_REDIRECT_URI=http://localhost:8844/api/integrations/procore/oauth/callback
# If you don't install `keyring`, set refresh token here after connecting:
PROCORE_REFRESH_TOKEN=
