FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN useradd -m -u 1000 trinity && chown -R trinity:trinity /app

USER trinity

EXPOSE 8001

CMD ["python", "-m", "uvicorn", "governance_sidecar:app", "--host", "0.0.0.0", "--port", "8001"]
