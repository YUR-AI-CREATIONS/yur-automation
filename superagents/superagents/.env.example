# Email: Your API keys go here

# Copy this file to: F:\New folder\cognitive_engine\superagents\.env
# Then fill in the missing values below

# ============================================================
# TRINITY BACKEND (✅ You have this)
# ============================================================
TRINITY_API_URL=https://yur-ai-api.onrender.com
TRINITY_API_KEY=legmAPxqbF+YUn7JCZD7zXbujSTRbkmhsWk1rHhKBzQ=

# ============================================================
# OPENAI (❌ NEED THIS - 5 minutes)
# ============================================================
# Get from: https://platform.openai.com/api-keys
# Cost: Pay-as-you-go (~$50/month typical)
# Steps:
#   1. Go to https://platform.openai.com/api-keys
#   2. Click "Create new secret key"
#   3. Copy the key (sk-...)
#   4. Paste below
OPENAI_API_KEY=sk-...PASTE_YOUR_KEY_HERE...

# ============================================================
# EMAIL PROVIDER (❌ NEED THIS - 5 minutes)
# ============================================================
# Use SendGrid (recommended - easiest setup):
#
# Get from: https://sendgrid.com
# Steps:
#   1. Sign up (free account)
#   2. Go to Settings → API Keys
#   3. Create API Key
#   4. Copy key (SG....)
#   5. Paste below
#
# Also need to verify FROM_EMAIL in SendGrid:
#   1. Sender Authentication → Single Sender
#   2. Add and verify your email (sales@yourcompany.com)
#   3. Use that email below as FROM_EMAIL

EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG....PASTE_YOUR_KEY_HERE...
FROM_EMAIL=sales@yourcompany.com
FROM_NAME=Trinity Sales

# ============================================================
# HUBSPOT CRM (❌ NEED THIS - 3 minutes)
# ============================================================
# Get from: https://app.hubspot.com
# Steps:
#   1. Sign up for free account
#   2. Settings → Integrations → Private Apps
#   3. Create Private App
#   4. Copy Access Token
#   5. Paste below
#
# Also get your Portal ID:
#   1. Settings → Account & Billing
#   2. Copy "Portal ID" number
#   3. Paste below

HUBSPOT_API_KEY=pat-...PASTE_YOUR_KEY_HERE...
HUBSPOT_PORTAL_ID=12345

# ============================================================
# YOUR DETAILS (❌ FILL IN - 1 minute)
# ============================================================
